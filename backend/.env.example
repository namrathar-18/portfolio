# --- Email (required) ---
# Gmail address that sends the mail
EMAIL_USER=you@gmail.com
# Google App Password (myaccount.google.com/apppasswords) — NOT your Gmail password
EMAIL_PASSWORD=xxxxxxxxxxxxxxxx
# Where messages land; defaults to EMAIL_USER when unset
EMAIL_TO=you@gmail.com

# --- Admin (optional) ---
# Secret required in the x-admin-key header to read/manage stored messages
ADMIN_KEY=change-me

# --- MongoDB Atlas (optional; email works without it) ---
# Credentials passed separately so '@' in the password is safe
MONGO_URI=mongodb+srv://your-cluster.mongodb.net/portfolio
MONGO_USER=your_db_user
MONGO_PASS=your_db_password

PORT=5000
NODE_ENV=development
